import tkinter as tk
from tkinter import filedialog, messagebox
import pandas as pd
import numpy as np
import matplotlib
matplotlib.use('TkAgg')
import matplotlib.pyplot as plt
import matplotlib.patches as mpatches
import os


AMINO_ACIDS = ['A', 'C', 'D', 'E', 'F', 'G', 'H', 'I', 'K', 'L',
               'M', 'N', 'P', 'Q', 'R', 'S', 'T', 'V', 'W', 'Y']


class FoldXAnalyzerApp:
    def __init__(self, root):
        self.root = root
        self.root.title("FoldX Genetic Analyzer & Visualizer")
        self.root.geometry("600x450")
        self.root.configure(padx=20, pady=20)


        self.label = tk.Label(root, text="FoldX import a .fxout folder.", font=("Arial", 12, "bold"))
        self.label.pack(pady=10)

        self.btn_file = tk.Button(root, text="Import a file (.fxout)", command=self.select_file, width=30)
        self.btn_file.pack(pady=5)

        self.btn_run = tk.Button(root, text="Start the analysis & Create an Excel", command=self.run_analysis, bg="green",
                                 fg="black", font=("Arial", 12, "bold"))
        self.btn_run.pack(pady=20)

        self.log_text = tk.Text(root, height=15, width=70, state=tk.DISABLED, bg="#f4f4f4")
        self.log_text.pack(pady=10)

        self.selected_path = None

    def log(self, message):

        self.log_text.config(state=tk.NORMAL)
        self.log_text.insert(tk.END, message + "\n")
        self.log_text.see(tk.END)
        self.log_text.config(state=tk.DISABLED)
        self.root.update()

    def select_file(self):

        self.root.lift()
        self.root.focus_force()
        file_path = filedialog.askopenfilename(
            parent=self.root,
            filetypes=[("FoldX Output", "*.fxout"), ("All Files", "*.*")]
        )
        if file_path:
            self.selected_path = file_path
            self.log(f"Imported File: {os.path.basename(file_path)}")

    def run_analysis(self):
        if not self.selected_path:
            messagebox.showwarning("Warning!", "Please select a file first!")
            return

        self.log("\n--- Analysis Begins ---")
        try:

            detailed_df = self.parse_fxout(self.selected_path)


            summary_df = self.calculate_statistics(detailed_df)


            base_filename = os.path.splitext(os.path.basename(self.selected_path))[0]
            export_dir = os.path.dirname(self.selected_path)
            export_path = os.path.join(export_dir, f"{base_filename}_Analiz.xlsx")

            try:
                with pd.ExcelWriter(export_path, engine='openpyxl') as writer:
                    summary_df.to_excel(writer, sheet_name='Ozet_Analiz', index=False)
                    detailed_df.to_excel(writer, sheet_name='Hesaplama_Detaylari', index=False)
                self.log(f"Success! The Excel file has been saved.:\n{export_path}")

            except PermissionError:
                messagebox.showerror("Open File Error",
                                     f"The Excel file is currently open in another program!\n\nPlease close and try again:\n{export_path}")
                self.log("ERROR: The Excel file could not be overwritten because it was already open!")
                return

            # 4. Grafiği Çiz
            self.plot_profile(summary_df, base_filename)

        except Exception as e:
            import traceback
            self.log(f"AN ERROR OCCURRED.: {str(e)}")
            self.log(traceback.format_exc())
            messagebox.showerror("Error", f"An error occurred during the process:\n{str(e)}")

    def parse_fxout(self, filepath):

        self.log("Reading and matching the file...")

        raw_df = pd.read_csv(filepath, sep='\t', skipinitialspace=True)
        raw_df.columns = raw_df.columns.str.strip()


        raw_df['Is_WT'] = raw_df['Pdb'].str.startswith('./WT_')


        extracted = raw_df['Pdb'].str.extract(r'_(\d+)_(\d+)\.pdb')
        raw_df['Mut_Index'] = pd.to_numeric(extracted[0])
        raw_df['Run_ID'] = pd.to_numeric(extracted[1])


        raw_df['AminoAcid'] = raw_df['Mut_Index'].apply(
            lambda x: AMINO_ACIDS[int(x) - 1] if pd.notnull(x) and 1 <= int(x) <= 20 else 'Unknown'
        )

        wt_df = raw_df[raw_df['Is_WT']][['Mut_Index', 'Run_ID', 'Interaction Energy']].copy()
        wt_df = wt_df.rename(columns={'Interaction Energy': 'WT_Energy'})

        mut_df = raw_df[~raw_df['Is_WT']][['Mut_Index', 'Run_ID', 'AminoAcid', 'Interaction Energy']].copy()
        mut_df = mut_df.rename(columns={'Interaction Energy': 'Mutant_Energy'})


        merged_df = pd.merge(mut_df, wt_df, on=['Mut_Index', 'Run_ID'], how='inner')


        merged_df['ddG'] = merged_df['Mutant_Energy'] - merged_df['WT_Energy']

        cols = ['AminoAcid', 'Mut_Index', 'Run_ID', 'Mutant_Energy', 'WT_Energy', 'ddG']
        valid_df = merged_df[cols].copy()

        self.log(f"Matching complete. Number of valid interactions: {len(valid_df)}")
        return valid_df

    def calculate_statistics(self, df):

        self.log("Statistics and decision labels are being prepared...")


        clean_df = df[df['ddG'] < 50.0].copy()

        stats = clean_df.groupby('AminoAcid').agg(
            Valid_Runs=('ddG', 'count'),
            MEAN_ddG=('ddG', 'mean'),
            STDEV_ddG=('ddG', 'std'),
            SEM_ddG=('ddG', 'sem')
        ).reset_index()

        stats['Decision_Status'] = stats['MEAN_ddG'].apply(
            lambda x: 'IDEAL CANDIDATE' if x < -0.5 else 'REJECTED'
        )

        stats['Order'] = stats['AminoAcid'].apply(
            lambda x: AMINO_ACIDS.index(x) if x in AMINO_ACIDS else 99
        )
        stats = stats.sort_values('Order').drop(columns=['Order'])

        basarili_sayisi = len(stats[stats['MEAN_ddG'] < -0.5])
        self.log(f"Number of ideal candidates exceeding the <-0.5 threshold: {basarili_sayisi}")

        return stats

    def plot_profile(self, summary_df, filename):

        self.log("The graph is being drawn...")

        fig, ax = plt.subplots(figsize=(12, 6))

        colors = ['#2ca02c' if val < -0.5 else '#d62728' for val in summary_df['MEAN_ddG']]

        ax.bar(
            summary_df['AminoAcid'],
            summary_df['MEAN_ddG'],
            yerr=summary_df['SEM_ddG'],
            capsize=5,
            color=colors,
            edgecolor='black',
            alpha=0.8
        )

        ax.axhline(y=-0.5, color='black', linestyle='--', linewidth=2, label='Threshold (-0.5 kcal/mol)')
        ax.axhline(y=0.0, color='gray', linestyle='-', linewidth=1)

        ax.set_title(f"Thermodynamic Mutational Profile\n{filename}", fontsize=14, fontweight='bold')
        ax.set_xlabel("Mutated Amino Acid", fontsize=12, fontweight='bold')
        ax.set_ylabel(r"$\Delta\Delta G$ (kcal/mol)", fontsize=12, fontweight='bold')

        green_patch = mpatches.Patch(color='#2ca02c', label='Ideal Candidate (< -0.5)')
        red_patch = mpatches.Patch(color='#d62728', label='Rejected (>= -0.5)')
        threshold_line = plt.Line2D([0], [0], color='black', linestyle='--', lw=2, label='Threshold (-0.5)')
        ax.legend(handles=[green_patch, red_patch, threshold_line], loc='upper right')

        ax.grid(axis='y', linestyle='--', alpha=0.7)
        plt.tight_layout()


        self.root.after(100, plt.show)
        self.log("The graph is being displayed...")


if __name__ == "__main__":
    root = tk.Tk()
    root.lift()
    root.attributes('-topmost', True)
    root.after_idle(root.attributes, '-topmost', False)
    app = FoldXAnalyzerApp(root)
    root.mainloop()
